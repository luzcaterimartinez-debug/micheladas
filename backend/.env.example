# =============================================================================
# Michelandia API — desarrollo local
# Copia a .env:  copy .env.example .env
# =============================================================================

APP_ENV=development

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=michelada

MYSQL_POOL_SIZE=5
MYSQL_CONNECTION_TIMEOUT=10
QUERY_CACHE_TTL_SECONDS=30
QUERY_CACHE_COMANDAS_TTL_SECONDS=8

# Genera uno seguro: python -c "from app.config import generate_jwt_secret; print(generate_jwt_secret())"
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_EXPIRE_MINUTES=480

# Orígenes del frontend (separados por coma, sin espacios extra)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
