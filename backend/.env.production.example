# =============================================================================
# Michelandia API — PRODUCCIÓN
# Copia a .env en el servidor (nunca subas .env a git).
# =============================================================================

APP_ENV=production

# --- MySQL (Hostinger, RDS, servidor propio) ---
MYSQL_HOST=tu-host.mysql.example.com
MYSQL_PORT=3306
MYSQL_USER=michelada_app
MYSQL_PASSWORD=contraseña-larga-y-única
MYSQL_DATABASE=michelada

MYSQL_POOL_SIZE=5
MYSQL_CONNECTION_TIMEOUT=10
QUERY_CACHE_TTL_SECONDS=30
QUERY_CACHE_COMANDAS_TTL_SECONDS=8

# Obligatorio en producción: mínimo 32 caracteres aleatorios
# Generar: python -c "from app.config import generate_jwt_secret; print(generate_jwt_secret())"
JWT_SECRET=
JWT_EXPIRE_MINUTES=480

# Solo dominios reales del frontend (HTTPS)
CORS_ORIGINS=https://tu-dominio.vercel.app,https://pos.tu-negocio.com
